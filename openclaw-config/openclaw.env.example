# =============================================================================
# OpenClaw Configuration
# =============================================================================
# Copia este archivo a /home/openclaw/.openclaw/.env en la instancia EC2
# y configura al menos una API key.
#
# Documentación: https://github.com/openclaw/openclaw
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (configura al menos una)
# -----------------------------------------------------------------------------

# OpenAI - https://platform.openai.com/api-keys
# Modelos: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# OPENAI_API_KEY=sk-...

# Anthropic (Claude) - https://console.anthropic.com/
# Modelos: claude-3-opus, claude-3-sonnet, claude-3-haiku
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini - https://aistudio.google.com/apikey
# Modelos: gemini-pro, gemini-1.5-pro
# GEMINI_API_KEY=...

# OpenRouter - https://openrouter.ai/keys
# Acceso a múltiples modelos con una sola API key
# OPENROUTER_API_KEY=sk-or-...

# -----------------------------------------------------------------------------
# Token de Autenticación
# -----------------------------------------------------------------------------

# Token para autenticar conexiones al gateway de OpenClaw
# Se genera automáticamente durante la instalación
# Puedes regenerarlo con: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# -----------------------------------------------------------------------------
# Configuración del Servidor
# -----------------------------------------------------------------------------

# Puerto del servidor (default: 3000)
# PORT=3000

# Host del servidor (default: 0.0.0.0)
# HOST=0.0.0.0

# Entorno (development | production)
NODE_ENV=production

# -----------------------------------------------------------------------------
# Configuración de Modelos
# -----------------------------------------------------------------------------

# Modelo por defecto para chat
# Ejemplos: gpt-4o, claude-3-sonnet-20240229, gemini-1.5-pro
# OPENCLAW_DEFAULT_MODEL=gpt-4o

# Modelo para tareas de código
# OPENCLAW_CODE_MODEL=gpt-4o

# Temperatura por defecto (0.0 - 2.0)
# OPENCLAW_DEFAULT_TEMPERATURE=0.7

# Máximo de tokens en respuesta
# OPENCLAW_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Almacenamiento y Estado
# -----------------------------------------------------------------------------

# Directorio para estado y datos de OpenClaw
# OPENCLAW_STATE_DIR=~/.openclaw

# Directorio para logs
# OPENCLAW_LOG_DIR=~/.openclaw/logs

# -----------------------------------------------------------------------------
# Configuración de Shell
# -----------------------------------------------------------------------------

# Cargar variables de entorno del shell del usuario
# OPENCLAW_LOAD_SHELL_ENV=1

# Shell a usar para comandos (default: /bin/bash)
# OPENCLAW_SHELL=/bin/bash

# -----------------------------------------------------------------------------
# Límites y Seguridad
# -----------------------------------------------------------------------------

# Timeout para ejecución de comandos (segundos)
# OPENCLAW_COMMAND_TIMEOUT=300

# Máximo de archivos a procesar en una operación
# OPENCLAW_MAX_FILES=100

# Tamaño máximo de archivo a leer (bytes)
# OPENCLAW_MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Nivel de log (debug | info | warn | error)
# LOG_LEVEL=info

# Formato de log (json | pretty)
# LOG_FORMAT=pretty

# -----------------------------------------------------------------------------
# Proxy (si estás detrás de un proxy corporativo)
# -----------------------------------------------------------------------------

# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1
